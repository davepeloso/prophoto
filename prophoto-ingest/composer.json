{
  "name": "prophoto/ingest",
  "description": "ProPhoto ingest domain package",
  "type": "library",
  "license": "proprietary",
  "require": {
    "php": "^8.2",
    "illuminate/support": "^11.0|^12.0",
    "illuminate/database": "^11.0|^12.0",
    "illuminate/events": "^11.0|^12.0",
    "illuminate/contracts": "^11.0|^12.0",
    "prophoto/contracts": "@dev",
    "prophoto/assets": "@dev",
    "prophoto/booking": "@dev"
  },
  "require-dev": {
    "orchestra/testbench": "^9.0|^10.0",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "ProPhoto\\Ingest\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ProPhoto\\Ingest\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "ProPhoto\\Ingest\\IngestServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit"
  },
  "repositories": [
    {
      "type": "path",
      "url": "../prophoto-*",
      "options": {
        "symlink": true
      }
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true
}
