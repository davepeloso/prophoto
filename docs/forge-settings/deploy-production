#!/bin/bash

#!/usr/bin/env bash
set -Eeuo pipefail

APP_DIR="/home/forge/mn8meta.com"
BRANCH="main"
LOG_PREFIX="[PROD DEPLOY]"

log() {
  printf "\n%s %s\n" "$LOG_PREFIX" "$1"
}

fail() {
  local exit_code=$?
  local line_no=${1:-unknown}
  echo
  echo "$LOG_PREFIX ERROR: deploy failed on line $line_no with exit code $exit_code"
  echo "$LOG_PREFIX PWD: $(pwd)"
  echo "$LOG_PREFIX Branch: $(git branch --show-current 2>/dev/null || echo 'unknown')"
  echo "$LOG_PREFIX Last commit: $(git rev-parse --short HEAD 2>/dev/null || echo 'unknown')"
  exit "$exit_code"
}

trap 'fail $LINENO' ERR

cd "$APP_DIR"

log "Starting deploy for branch: $BRANCH"
log "App dir: $APP_DIR"

log "Fetching latest code"
git fetch origin

log "Checking out remote branch exactly"
git checkout -B "$BRANCH" "origin/$BRANCH"
git reset --hard "origin/$BRANCH"

log "Current commit: $(git rev-parse --short HEAD)"
git --no-pager log -1 --oneline

log "Installing PHP dependencies"
$FORGE_COMPOSER install \
  --no-dev \
  --no-interaction \
  --prefer-dist \
  --optimize-autoloader \

log "Reloading PHP-FPM"
touch /tmp/fpmlock 2>/dev/null || true
(
  flock -w 10 9 || exit 1
  echo "$LOG_PREFIX Reloading PHP-FPM service: $FORGE_PHP_FPM"
  sudo -S service "$FORGE_PHP_FPM" reload
) 9</tmp/fpmlock

log "Preparing npm environment"
NPM_CI_FLAGS="--no-audit --progress=false"
NPM_VERSION="$(npm -v || echo "0")"

if echo "$NPM_VERSION" | grep -E '^(7|8|9|10)\.' >/dev/null; then
  NPM_CI_FLAGS="$NPM_CI_FLAGS --include=dev"
else
  export NPM_CONFIG_PRODUCTION=false
  export NODE_ENV=development
fi

echo "$LOG_PREFIX Using npm version: $NPM_VERSION"
echo "$LOG_PREFIX Running: npm ci $NPM_CI_FLAGS"

log "Installing Node dependencies"
npm ci $NPM_CI_FLAGS

log "Generating Ziggy routes"
php artisan ziggy:generate resources/js/ziggy.js

log "Building frontend assets"
npm run build

log "Running database migrations"
php artisan migrate --force

log "Clearing and rebuilding Laravel caches"
php artisan optimize:clear
php artisan config:cache
php artisan route:cache
php artisan view:cache

log "Restarting queue workers"
php artisan queue:restart

log "Production Deployment finished successfully"